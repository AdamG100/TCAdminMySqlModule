@model MySqlModule.Models.MySql.MySqlModel

@{
    Page.Title = "MySql Management";
    <script>
        $(document).ready(function () {
            document.title = "@TCAdmin.SDK.Web.MVC.Template.GetSelectedTemplateTitle() " + "MySql Manager";
            $('.header-text').html("MySql Manager")
        });
    </script>
    Layout = this.GetTemplateFile("Shared/Main.cshtml", true);
}

@section sidebar{
    @Html.Partial("_DefaultSidebar")
}

<link rel="stylesheet" href="../Views/@TCAdmin.SDK.Web.MVC.Template.GetSelectedTemplate()/ThemeBuilder.css">
<link rel="stylesheet" href="../Views/@TCAdmin.SDK.Web.MVC.Template.GetSelectedTemplate()/Custom.css">

<style>
    body { line-height: 1.4 !important; }

    .mysql-wrap { padding: 6px 10px 30px; }

    /* Stat tiles — proper cards */
    .mysql-stats { display: flex; flex-wrap: wrap; gap: 14px; margin-bottom: 24px; }
    .mysql-stat {
        flex: 1 1 180px;
        background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.1);
        border-radius: 12px; padding: 16px 20px;
    }
    .mysql-stat-label { font-size: .68rem; text-transform: uppercase; letter-spacing: .8px; color: rgba(255,255,255,.45); margin-bottom: 8px; }
    .mysql-stat-value { font-size: 1.7rem; font-weight: 700; color: #fff; line-height: 1.1; }
    .mysql-stat-value.is-text { font-size: 1.1rem; }
    .mysql-stat-value .muted { color: rgba(255,255,255,.38); font-weight: 500; font-size: 1.2rem; }

    /* Layout: db panel grows to fill remaining space, manage panel fixed right */
    .mysql-layout { display: flex; flex-wrap: wrap; gap: 20px; align-items: flex-start; }
    .mysql-layout .col-xl-8 { flex: 1 1 0; min-width: 0; padding: 0; max-width: none; }
    .mysql-side { flex: 0 0 420px; min-width: 0; }

    /* Panels */
    .mysql-db-panel, .mysql-manage-panel {
        background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.09);
        border-radius: 12px; padding: 20px;
    }
    .mysql-panel-head { display: flex; align-items: center; gap: 10px; margin-bottom: 18px; }
    .mysql-panel-title { margin: 0; font-size: 1rem; font-weight: 700; color: #fff; }
    .mysql-db-count { background: rgba(43,139,255,.18); color: #5aa9ff; border-radius: 20px; padding: 2px 11px; font-size: .8rem; font-weight: 700; }

    /* Database cards */
    .mysql-db-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 16px; }
    .mysql-db-card {
        background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.1);
        border-radius: 10px; padding: 16px; transition: border-color .2s;
    }
    .mysql-db-card:hover { border-color: rgba(74,163,255,.5); }
    .mysql-db-card-head { display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-bottom: 14px; }
    .mysql-db-name { font-weight: 700; font-size: 1rem; color: #fff; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .mysql-loc-badge { font-size: .7rem; color: rgba(255,255,255,.5); background: rgba(255,255,255,.07); border-radius: 20px; padding: 3px 9px; white-space: nowrap; }

    /* Credential fields */
    .mysql-fields { display: flex; flex-direction: column; gap: 10px; }
    .mysql-field { display: flex; flex-direction: column; gap: 3px; }
    .mysql-field-label { font-size: .65rem; text-transform: uppercase; letter-spacing: .7px; color: rgba(255,255,255,.4); }
    .mysql-field-value-wrap {
        display: flex; align-items: center; gap: 6px;
        background: rgba(0,0,0,.25); border: 1px solid rgba(255,255,255,.1);
        border-radius: 8px; padding: 6px 6px 6px 10px;
    }
    .mysql-field-value {
        flex: 1; font-family: Consolas, 'Courier New', monospace; font-size: .82rem;
        color: rgba(255,255,255,.85); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .mysql-icon-btn {
        background: transparent; border: none; color: rgba(255,255,255,.45);
        cursor: pointer; padding: 4px 7px; border-radius: 6px; line-height: 1;
        transition: background .15s, color .15s;
    }
    .mysql-icon-btn:hover { background: rgba(255,255,255,.1); color: #fff; }
    .mysql-icon-btn.copied { color: #34d399 !important; }

    /* Card action buttons */
    .mysql-db-actions { display: flex; gap: 8px; margin-top: 16px; }
    .mysql-btn {
        flex: 1; display: inline-flex; align-items: center; justify-content: center; gap: 7px;
        padding: 8px 10px; border-radius: 8px; font-size: .8rem; font-weight: 600;
        text-decoration: none; cursor: pointer; border: none; transition: filter .15s, background .15s;
    }
    .mysql-btn-primary { background: linear-gradient(135deg, #2b8bff, #1f6fe0); color: #fff; }
    .mysql-btn-primary:hover { filter: brightness(1.12); color: #fff; text-decoration: none; }
    .mysql-btn-ghost { background: rgba(255,255,255,.07); color: rgba(255,255,255,.75); }
    .mysql-btn-ghost:hover { background: rgba(255,255,255,.13); color: #fff; text-decoration: none; }

    /* Empty state */
    .mysql-empty { text-align: center; padding: 44px 16px; color: rgba(255,255,255,.4); }
    .mysql-empty-icon { font-size: 2.4rem; margin-bottom: 12px; }

    /* Manage panel form groups */
    .mysql-form-group { margin-bottom: 14px; }
    .mysql-form-label {
        display: block; font-size: .72rem; text-transform: uppercase;
        letter-spacing: .8px; color: rgba(255,255,255,.6); margin-bottom: 7px; font-weight: 600;
    }
    .mysql-form-hint { font-size: .7rem; color: rgba(255,255,255,.35); margin-top: 5px; }
    /* Prefix + db name as a single unified input */
    .mysql-combined-input {
        display: flex; align-items: stretch;
        border: 2px solid rgba(255,255,255,.28); border-radius: 10px; overflow: hidden;
        transition: border-color .18s, box-shadow .18s;
    }
    .mysql-combined-input:focus-within {
        border-color: rgba(74,163,255,.8);
        box-shadow: 0 0 0 3px rgba(43,139,255,.2);
    }
    .mysql-prefix-label {
        padding: 10px 12px; background: rgba(255,255,255,.1); color: rgba(255,255,255,.65);
        font-family: Consolas, 'Courier New', monospace; font-size: .9rem; white-space: nowrap;
        border-right: 2px solid rgba(255,255,255,.15); display: flex; align-items: center;
    }
    .mysql-db-name-input {
        flex: 1; padding: 10px 12px; background: transparent !important;
        border: none !important; outline: none !important; box-shadow: none !important;
        color: #fff !important; font-size: .9rem; min-width: 0;
    }
    .mysql-db-name-input::placeholder { color: rgba(255,255,255,.38); }
    /* Force Kendo dropdowns to full width in manage panel */
    .mysql-manage-panel span.k-dropdown { display: block; width: 100% !important; box-sizing: border-box; }
    .mysql-manage-section { margin-bottom: 0; }

    /* Toast */
    .mysql-toast {
        position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(20px);
        background: #1a2232; color: #fff; border: 1px solid rgba(255,255,255,.12);
        padding: 10px 18px; border-radius: 10px; font-size: .85rem; font-weight: 600;
        opacity: 0; pointer-events: none; transition: opacity .2s, transform .2s; z-index: 9999;
        box-shadow: 0 8px 28px rgba(0,0,0,.5);
    }
    .mysql-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
    .mysql-toast i { color: #34d399; margin-right: 7px; }
</style>

<div class="mysql-wrap">
    <div class="mysql-stats">
        <div class="mysql-stat">
            <div class="mysql-stat-label">Databases Allowed</div>
            <div class="mysql-stat-value">@Model.CurrentDatabases <span class="muted">/ @Model.MaxDatabases</span></div>
        </div>
        <div class="mysql-stat">
            <div class="mysql-stat-label">Eligible Locations</div>
            <div class="mysql-stat-value is-text">@(string.Join(" • ", Model.EligibleLocations.Datacenters.Select(x => x.Location)))</div>
        </div>
    </div>

    <div class="mysql-layout">
        @Html.Partial("_Databases", Model.Databases)

        <div class="mysql-side">
            <div class="mysql-manage-panel">
                <div class="mysql-panel-head">
                    <h6 class="mysql-panel-title">Manage Databases</h6>
                </div>

                @if (Model.CurrentDatabases < Model.MaxDatabases)
                {
                    <div class="mysql-manage-section">
                        @using (Ajax.BeginForm("CreateDatabase", "MySql", null))
                        {
                            <div class="mysql-form-group">
                                <div class="mysql-form-label">Database Name</div>
                                <div class="mysql-combined-input">
                                    <span class="mysql-prefix-label">@Model.CreationUsername</span>
                                    <input type="text" name="requestDbName" class="mysql-db-name-input" placeholder="my_database" autocomplete="off" />
                                </div>
                                <div class="mysql-form-hint">Letters, numbers and underscores only</div>
                            </div>
                            <div class="mysql-form-group">
                                <div class="mysql-form-label">For Service</div>
                                @Html.Kendo().DropDownList().Name("requestServiceId1").BindTo(Model.CreationServiceIds).HtmlAttributes(new { style = "width: 100%;", @class = "k-primary" })
                            </div>
                            @Html.Kendo().Button().Name("Create").Content("Create Database").HtmlAttributes(new { style = "width: 100%; margin-top: 4px;", @class = "k-primary" })
                        }
                    </div>
                }

                @if (Model.CurrentDatabases > 0)
                {
                    <hr class="mysql-hr" />
                    <div class="mysql-manage-section">
                        @using (Ajax.BeginForm("DeleteDatabase", "MySql", null))
                        {
                            <div class="mysql-form-group">
                                <div class="mysql-form-label">Delete Database</div>
                                @Html.Kendo().DropDownList().Name("requestServiceId2").BindTo(Model.DeletionUsernames).HtmlAttributes(new { style = "width: 100%;", @class = "k-primary" })
                            </div>
                            @Html.Kendo().Button().Name("Delete").Content("Delete Database").HtmlAttributes(new { style = "width: 100%; margin-top: 4px;", @class = "k-primary" })
                        }
                    </div>

                    <hr class="mysql-hr" />
                    <div class="mysql-manage-section">
                        @using (Ajax.BeginForm("ResetPassword", "MySql", null))
                        {
                            <div class="mysql-form-group">
                                <div class="mysql-form-label">Reset Password</div>
                                @Html.Kendo().DropDownList().Name("requestServiceId3").BindTo(Model.ResetUsernames).HtmlAttributes(new { style = "width: 100%;", @class = "k-primary" })
                            </div>
                            @Html.Kendo().Button().Name("Reset").Content("Reset Password").HtmlAttributes(new { style = "width: 100%; margin-top: 4px;", @class = "k-primary" })
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="mysql-toast" id="mysqlToast"><i class="fas fa-check"></i><span>Copied to clipboard</span></div>

<script>
    (function () {
        function showToast(msg) {
            var t = document.getElementById('mysqlToast');
            if (!t) return;
            t.querySelector('span').textContent = msg;
            t.classList.add('show');
            clearTimeout(t._timer);
            t._timer = setTimeout(function () { t.classList.remove('show'); }, 1400);
        }

        function copyText(text, done) {
            if (navigator.clipboard && window.isSecureContext) {
                navigator.clipboard.writeText(text).then(done).catch(fallback);
            } else { fallback(); }
            function fallback() {
                var ta = document.createElement('textarea');
                ta.value = text; ta.style.position = 'fixed'; ta.style.top = '-1000px'; ta.style.opacity = '0';
                document.body.appendChild(ta); ta.focus(); ta.select();
                try { document.execCommand('copy'); } catch (e) { }
                document.body.removeChild(ta); if (done) done();
            }
        }

        $(document).on('click', '.mysql-copy', function () {
            var btn = this;
            var text = btn.getAttribute('data-copy') || '';
            copyText(text, function () {
                var icon = btn.querySelector('i');
                var prev = icon.className;
                icon.className = 'fas fa-check';
                btn.classList.add('copied');
                showToast('Copied to clipboard');
                setTimeout(function () { icon.className = prev; btn.classList.remove('copied'); }, 1200);
            });
        });

        $(document).on('click', '.mysql-reveal', function () {
            var wrap = this.closest('.mysql-field-value-wrap');
            var val = wrap.querySelector('.mysql-field-value');
            var icon = this.querySelector('i');
            if (val.classList.contains('revealed')) {
                val.classList.remove('revealed');
                val.textContent = '••••••••••';
                icon.className = 'fas fa-eye';
            } else {
                val.classList.add('revealed');
                val.textContent = val.getAttribute('data-value');
                icon.className = 'fas fa-eye-slash';
            }
        });
    })();
</script>

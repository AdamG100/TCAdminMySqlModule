@model List<MySqlModule.Models.MySql.MySqlGridViewModel>

@helper Field(string label, string value, bool secret)
{
    <div class="mysql-field">
        <span class="mysql-field-label">@label</span>
        <div class="mysql-field-value-wrap">
            <span class="mysql-field-value" data-value="@value">@(secret ? "••••••••••" : value)</span>
            @if (secret)
            {
                <button type="button" class="mysql-icon-btn mysql-reveal" title="Show / hide"><i class="fas fa-eye"></i></button>
            }
            <button type="button" class="mysql-icon-btn mysql-copy" data-copy="@value" title="Copy @label"><i class="fas fa-copy"></i></button>
        </div>
    </div>
}

<div class="col-xl-8 col-lg-7">
    <div class="mysql-db-panel">
        <div class="mysql-panel-head">
            <h6 class="mysql-panel-title">Configured Databases</h6>
            <span class="mysql-db-count">@Model.Count</span>
        </div>

        @if (Model.Count == 0)
        {
            <div class="mysql-empty">
                <div class="mysql-empty-icon"><i class="fas fa-database"></i></div>
                <div>You haven't created any databases yet.</div>
            </div>
        }
        else
        {
            <div class="mysql-db-grid">
                @foreach (var db in Model)
                {
                    <div class="mysql-db-card">
                        <div class="mysql-db-card-head">
                            <div class="mysql-db-name" title="@db.DatabaseName">@db.DatabaseName</div>
                            <span class="mysql-loc-badge"><i class="fas fa-map-marker-alt"></i> @db.DatabaseLocation</span>
                        </div>
                        <div class="mysql-fields">
                            @Field("Host", db.DatabaseHost, false)
                            @Field("Database", db.DatabaseName, false)
                            @Field("Username", db.DatabaseUsername, false)
                            @Field("Password", db.DatabasePassword, true)
                        </div>
                        <div class="mysql-db-actions">
                            @{
                                var isLocal = db.DatabaseHost == "localhost" || db.DatabaseHost == "127.0.0.1";
                                var hasLink = !string.IsNullOrEmpty(db.DatabaseLink);
                            }
                            @if (!isLocal && hasLink)
                            {
                                <form id="pma-@db.ServiceId" method="post" action="@(db.DatabaseLink)index.php"
                                      target="_blank" style="display:none">
                                    <input type="hidden" name="pma_username" value="@db.DatabaseUsername" />
                                    <input type="hidden" name="pma_password" value="@db.DatabasePassword" />
                                    <input type="hidden" name="server" value="1" />
                                </form>
                                <button type="button" class="mysql-btn mysql-btn-primary"
                                        onclick="document.getElementById('pma-@db.ServiceId').submit()">
                                    <i class="fas fa-external-link-alt"></i> phpMyAdmin
                                </button>
                            }
                            <a class="mysql-btn mysql-btn-ghost" target="_blank" rel="noopener" href="/Service/Home/@db.ServiceId">
                                <i class="fas fa-server"></i> Service
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
